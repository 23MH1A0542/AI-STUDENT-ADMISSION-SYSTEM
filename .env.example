# ==============================================================================
# AI Student Admissions System - Environment Variables Template
# Copy this file to .env and fill in the values.
# ==============================================================================

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=student_admissions
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres_secure_pass@db:5432/student_admissions

# FastAPI Configuration
BACKEND_PORT=8000
API_V1_STR=/api/v1
PROJECT_NAME="AI Student Admissions System"

# Security Configuration
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=super_secret_jwt_signing_key_change_me_in_production_12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI Configuration (Gemini API)
# Get your API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Email Configuration (SMTP Simulation)
# For production, replace these with real SMTP settings
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=mock_user
SMTP_PASSWORD=mock_password
SMTP_FROM=admissions@university.edu

# Docker environment flag
ENVIRONMENT=development
